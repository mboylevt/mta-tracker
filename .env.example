# Required: MTA Bus Time API key (get one at https://bustime.mta.info/wiki/Developers/Index)
MTA_BUS_API_KEY=your_api_key_here

# Optional: Override subway stop IDs (default: Ditmars Blvd N/W)
# SUBWAY_STOP_IDS=R01N,R01S

# Optional: Override bus stop IDs
# BUS_STOP_IDS=553026,553102

# Optional: Data refresh interval in seconds (default: 30)
# REFRESH_INTERVAL_SECONDS=30
